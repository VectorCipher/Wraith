# ==============================================
# WRAITH — Environment Configuration
# ==============================================

# ----------------------------------------------
# OLLAMA (Local LLM Server)
# ----------------------------------------------
# Where Ollama is running
OLLAMA_HOST=http://localhost:11434

# Max seconds to wait for LLM response
OLLAMA_TIMEOUT=120


# ----------------------------------------------
# LLM MODELS
# ----------------------------------------------
# Change these to swap models — no code changes needed
# Run: ollama list  — to see what you have
# Run: ollama pull <model>  — to download a model

#Model
Model = Your Model name


# ----------------------------------------------
# GO SCANNER (gRPC Attack Engine)
# ----------------------------------------------
# Host and port where the Go scanner listens
SCANNER_GRPC_HOST=localhost
SCANNER_GRPC_PORT=9090


# ----------------------------------------------
# SCANNING DEFAULTS
# ----------------------------------------------
# Max parallel HTTP requests the scanner can fire
MAX_CONCURRENT_REQUESTS=50

# Seconds before a single HTTP request times out
REQUEST_TIMEOUT=30

# Max requests per second to avoid crashing the target
SCAN_RATE_LIMIT=100


# ----------------------------------------------
# STORAGE
# ----------------------------------------------
# SQLite database for scan history and results
DB_PATH=./data/wraith.db

# Where generated reports are saved
REPORT_OUTPUT_DIR=./reports


# ----------------------------------------------
# v2: MEMORY SYSTEM
# ----------------------------------------------
# ChromaDB vector store persistence directory
CHROMA_PATH=./data/chroma

# Skill documents directory (Markdown files)
SKILLS_PATH=./data/skills

# Max skills retrieved from memory per scan
MAX_SKILL_RETRIEVAL=10


# ----------------------------------------------
# v2: CVE & EXPLOIT FEED
# ----------------------------------------------
# Enable automatic feed ingestion (true/false)
FEED_ENABLED=false

# Hours between automatic ingestion cycles
FEED_INTERVAL_HOURS=24

# Comma-separated feed sources: nvd,exploitdb,nuclei
FEED_SOURCES=nvd,exploitdb,nuclei

# Optional: NVD API key for higher rate limits
# Get one free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=


# ----------------------------------------------
# LOGGING
# ----------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO